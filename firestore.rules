rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user has a specific role
    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    // Helper function to check if the user has a specific designation
    function hasDesignation(designation) {
       return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.designation == designation;
    }
    
    // Users can only read their own data, but admins can read/write any user document
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
      allow create: if hasRole('admin');
    }
    
    // Admins can manage assignments
    match /salesmanCrmAssignments/{assignmentId} {
        allow read, write: if hasRole('admin');
    }

    // Orders can be read by any authenticated user, but only created/updated by admins or employees.
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if hasRole('admin') || hasRole('employee');
      allow delete: if hasRole('admin');
    }

    // Purchase Requests can be read by any authenticated user, but only created/updated by admins or employees.
    match /purchaseRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create, update: if hasRole('admin') || hasRole('employee') || hasDesignation('PC');
      allow delete: if hasRole('admin');
    }
    
    // Stock data can be read by authenticated users, but only managed by admins.
    match /stocks/{stockId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }
    
    // Customer and subcollection rules
    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, write: if hasRole('admin') || hasRole('employee');
      
      match /deals/{dealId} {
        allow read: if isAuthenticated();
        allow create, write: if hasRole('admin') || hasRole('employee');
        
        match /quotations/{quotationId} {
            allow read: if isAuthenticated();
            allow create, write: if hasRole('admin') || hasRole('employee');
        }
        
        match /orders/{orderId} {
            allow read: if isAuthenticated();
            allow create, write: if hasRole('admin') || hasRole('employee');
        }

        match /visits/{visitId} {
            allow read: if isAuthenticated();
            allow create, write: if hasRole('admin') || hasRole('employee');
        }

        match /measurements/{measurementId} {
            allow read: if isAuthenticated();
            allow create, write: if hasRole('admin') || hasRole('employee');
        }
        
        match /cpds/{cpdId} {
            allow read: if isAuthenticated();
            allow create, write: if hasRole('admin') || hasRole('employee');
        }
      }
    }
    
    // NEW: Rule to allow the 'Approve Quotation' page to work.
    // This allows authenticated users to query the 'quotations' collection group.
    match /{path=**}/quotations/{quotationId} {
      allow read: if isAuthenticated();
    }
  }
}
