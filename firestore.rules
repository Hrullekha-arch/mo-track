
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin role
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check for employee role
    function isEmployee() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee';
    }

    // Helper function to check for installer role
    function isInstaller() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'installer';
    }
    
    // Helper function to check for any authenticated user
    function isSignedIn() {
      return request.auth != null;
    }

    // Users Collection
    match /users/{userId} {
      // Admins can read/write any user. Users can read/update their own profile.
      allow read, update: if isAdmin() || request.auth.uid == userId;
      // Only admins can create or delete users.
      allow create, delete: if isAdmin();
    }
    
    // SalesmanCrmAssignments Collection
    match /salesmanCrmAssignments/{assignmentId} {
        allow read, write: if isAdmin() || isEmployee();
    }
    
    // Customers Collection and Subcollections
    match /customers/{customerId} {
      allow read, create, update: if isAdmin() || isEmployee();
      
      // Deals subcollection
      match /deals/{dealId} {
        allow read, create, update: if isAdmin() || isEmployee();
        
        // Quotations subcollection
        match /quotations/{quotationId} {
            allow read, create, update: if isAdmin() || isEmployee();
        }
        
        // Orders subcollection within deals
        match /orders/{orderId} {
            allow read, create, update: if isAdmin() || isEmployee();
        }
        
        // Visits subcollection within deals
        match /visits/{visitId} {
            allow read, create: if isAdmin() || isEmployee();
            allow update: if (isAdmin() || isEmployee()) || (isInstaller() && resource.data.assignedTo == request.auth.uid);
        }
        
        // Other subcollections
        match /{subcollection}/{docId} {
            allow read, create, update, delete: if isAdmin() || isEmployee();
        }
      }
    }
    
    // Visits Collection Group (for cross-customer queries)
    match /{path=**}/visits/{visitId} {
      // Admins and employees can list all visits. Installers can read visits assigned to them.
      allow read: if isAdmin() || isEmployee() || (isInstaller() && get(path).data.assignedTo == request.auth.uid);
    }

    // Orders Collection
    match /orders/{orderId} {
        allow read: if isSignedIn(); // Customers, installers, employees, admins can read
        allow create, delete: if isAdmin();
        // Admins and employees can update. Installers can only update orders assigned to them.
        allow update: if (isAdmin() || isEmployee()) || (isInstaller() && resource.data.assignedTo == request.auth.uid);
    }
    
    // O2D Collection
    match /o2d/{dealId} {
        allow read, create: if isAdmin() || isEmployee();
        // Allow installers to update to complete the final step
        allow update: if (isAdmin() || isEmployee()) || isInstaller();
    }

    // PurchaseRequests Collection
    match /purchaseRequests/{requestId} {
        allow read, create, update: if isAdmin() || isEmployee();
    }
    
    // Inbounds Collection
    match /inbounds/{inboundId} {
         allow read, create, update: if isAdmin() || isEmployee();
    }
    
    // Stocks Collection
    match /stocks/{stockId} {
        allow read: if isSignedIn();
        allow create, update: if isAdmin() || isEmployee();
        
        match /{subcollection}/{transactionId} {
             allow read, create, update, delete: if isAdmin() || isEmployee();
        }
    }
    
    // ApprovedQuotations, Invoices, Cutting, invoiceBatches Collections
    match /{collectionId}/{docId} {
        // Default deny all
        allow read, write: if false;
    }
    match /approvedQuotations/{quotationId} {
        allow read, create: if isAdmin() || isEmployee();
    }
    match /invoices/{invoiceId} {
        allow read, create: if isAdmin() || isEmployee();
    }
     match /Cutting/{taskId} {
        allow read, create, update: if isAdmin() || isEmployee();
    }
    match /invoiceBatches/{batchId} {
        allow read, create, update: if isAdmin() || isEmployee();
    }
  }
}
