
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to get the user's role from the users collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    // Helper function to check if the user is an admin
    function isAdmin(userId) {
      return getUserRole(userId) == 'admin';
    }

    // Helper function to check if the user is an employee
    function isEmployee(userId) {
      return getUserRole(userId) == 'employee';
    }
    
    // Helper function to check if the user is an installer
    function isInstaller(userId) {
      return getUserRole(userId) == 'installer';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can read/write any user document
      // Authenticated users can read their own document
      allow read: if request.auth != null && (isAdmin(request.auth.uid) || request.auth.uid == userId);
      // Admins can create/update any user.
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    // Rules for the 'orders' collection
    match /orders/{orderId} {
      // Allow public read for customer tracking page, but only specific, non-sensitive fields
      allow get: if true; 

      // Admins and Employees can list all orders. Installers can only see their assigned orders.
      allow list: if request.auth != null && (isAdmin(request.auth.uid) || isEmployee(request.auth.uid) || isInstaller(request.auth.uid));

      // Creation is allowed by Admins or Employees
      allow create: if request.auth != null && (isAdmin(request.auth.uid) || isEmployee(request.auth.uid));

      // Update rules are more complex
      allow update: if request.auth != null && (
        // Admins can update anything
        isAdmin(request.auth.uid) ||
        // Employees can update if they are the handler or if no handler is assigned
        (isEmployee(request.auth.uid)) ||
        // Installers can only update milestones if they are assigned to the order
        (isInstaller(request.auth.uid) && resource.data.assignedTo == request.auth.uid)
      );

      // Admins can delete orders
      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }
  }
}
