
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user has a specific role
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isDesignation(designation) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.designation == designation;
    }
    
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    // Admins can do anything
    match /{path=**}/documents/{document} {
      allow read, write: if isRole('admin');
    }

    // == Users Collection ==
    // Users can read public user info, but only admins can write.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }
    
    // == Salesman to CRM Assignments ==
    // Only admins and employees can manage these assignments.
    match /salesmanCrmAssignments/{assignmentId} {
        allow read, write: if isRole('admin') || isRole('employee');
    }

    // == Orders Collection ==
    match /orders/{orderId} {
      // Unauthenticated users can read a single order for tracking.
      allow get: if !isSignedIn();

      // Admins and Employees can read all orders.
      allow list, get: if isRole('admin') || isRole('employee');
      
      // Installers can only read orders assigned to them.
      allow get: if isRole('installer') && resource.data.assignedTo == request.auth.uid;
      
      // Creating new orders
      allow create: if isRole('admin') || isRole('employee');
      
      // Updating orders has role-specific logic
      allow update: if (isRole('admin') || isRole('employee')) ||
                       (isRole('installer') && resource.data.assignedTo == request.auth.uid);
                       
      allow delete: if isRole('admin');
      
      match /allocations/{allocationId} {
        allow read, write: if isRole('admin') || isRole('employee');
      }
    }
    
    // == Customers and all sub-collections ==
    // Admins and employees have full control over customer relationship data.
    match /customers/{customerId}/{path=**} {
        allow read, write: if isRole('admin') || isRole('employee');
    }
    
    // == Approved Quotations (for reporting/history) ==
    match /approvedQuotations/{quotationId} {
       allow read, write: if isRole('admin') || isRole('employee') || isRole('Accounts');
    }

    // == Purchase Requests Collection ==
    match /purchaseRequests/{requestId} {
      allow read, write: if isRole('admin') || isRole('employee') || isRole('Accounts');
    }
    
    // == Inbounds Collection ==
    match /inbounds/{inboundId} {
       allow read, write: if isRole('admin') || isRole('employee');
    }

    // == Stock Management ==
    // Only allow authenticated users to read stock data.
    // Writing to stock is locked down to be handled ONLY by backend/server functions.
    match /stocks/{stockId} {
      allow read: if isSignedIn();
      allow write: if false; // IMPORTANT: Prevent all client-side writes
      
      // Sub-collections for transactions are also server-only
      match /{collection}/{transactionId} {
         allow read, write: if false;
      }
    }
  }
}
