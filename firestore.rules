
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the role of the requesting user
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Helper function to get the designation of the requesting user
    function getUserDesignation(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.designation;
    }

    // By default, deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection rules
    match /users/{userId} {
      // Any authenticated user can read user profiles (to get names, roles, etc.)
      allow read: if request.auth != null;
      // Only admins can create, update, or delete users.
      // A user can update their own profile (e.g., for profile picture changes, not yet implemented but good to have)
      allow write: if getUserRole(request.auth.uid) == 'admin' || request.auth.uid == userId;
    }

    // Orders collection rules
    match /orders/{orderId} {
      // Unauthenticated users can read if they know the document ID (tracking code)
      allow get: if request.auth == null;

      // Authenticated users
      allow read: if request.auth != null &&
                  ( getUserRole(request.auth.uid) == 'admin' ||
                    getUserRole(request.auth.uid) == 'employee' ||
                    (getUserRole(request.auth.uid) == 'installer' && resource.data.assignedTo == request.auth.uid)
                  );
                  
      // Admins and employees can create and update anything.
      // Installers can only update specific fields on orders assigned to them.
      allow create: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'employee');
      allow update: if request.auth != null &&
                    ( getUserRole(request.auth.uid) == 'admin' ||
                      getUserRole(request.auth.uid) == 'employee' ||
                      ( // Installer-specific update rules
                        getUserRole(request.auth.uid) == 'installer' &&
                        resource.data.assignedTo == request.auth.uid &&
                        request.resource.data.keys().hasOnly(['milestones', 'feedbackRating', 'feedbackRemarks', 'bypassedOtp', 'completedAt'])
                      )
                    );
      allow delete: if getUserRole(request.auth.uid) == 'admin';
    }

    // Customer data rules (customers and all subcollections)
    match /customers/{customerId}/{document=**} {
        allow read, write: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'employee');
    }

    // Purchase Requests collection rules
    match /purchaseRequests/{requestId} {
        allow read, write: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'employee');
        // A more granular rule for approving
        allow update: if request.auth != null &&
                      ( getUserRole(request.auth.uid) == 'admin' ||
                        // Allow Accounts to approve
                        (getUserRole(request.auth.uid) == 'Accounts' && request.resource.data.status == 'Approved') ||
                        // Allow other employees to update but not approve without being an account manager or admin
                        (getUserRole(request.auth.uid) == 'employee' && request.resource.data.status != 'Approved')
                      );
    }
    
    // Inbounds collection rules
    match /inbounds/{inboundId} {
        allow read, write: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'employee');
    }

    // Stock collection rules
    // Reading is allowed for any authenticated user to check stock levels.
    // Writing (updating quantity) is denied from the client and must be done via secure server actions.
    match /stocks/{stockId} {
      allow read: if request.auth != null;
      allow write: if false; // Prevent all client-side writes
    }
    
    // Transactions should be created by the backend only.
    match /stocks/{stockId}/{transactionCollection}/{transactionId} {
        allow write: if false;
        allow read: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'employee');
    }

    // Rules for salesman assignments
    match /salesmanCrmAssignments/{assignmentId} {
      allow read, write: if request.auth != null &&
                        ( getUserRole(request.auth.uid) == 'admin' ||
                          (getUserRole(request.auth.uid) == 'employee' && getUserDesignation(request.auth.uid) == 'PC')
                        );
    }
    
    // Rules for approved quotations (used for reference)
    match /approvedQuotations/{quotationId} {
       allow read, write: if request.auth != null && (getUserRole(request.auth.uid) == 'admin' || getUserRole(request.auth.uid) == 'employee');
    }
  }
}
