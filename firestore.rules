
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow any authenticated user to read and write to any collection.
    // This is a permissive rule set suitable for trusted internal users.
    // For more granular control, you would add more specific `allow` conditions.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // This rule is crucial for the "All Visits" page to work.
    // It allows the app to query the "visits" collection across all documents.
    match /{path=**}/visits/{visitId} {
        allow read, write: if request.auth != null;
    }
  }
}
