rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check user role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Admins can manage all user documents
      allow write: if getUserRole(request.auth.uid) == 'admin';

      // Any authenticated user can read user documents (e.g., to get names for dropdowns)
      allow read: if request.auth != null;
    }

    // Rules for the 'orders' collection
    match /orders/{orderId} {
      // Allow unauthenticated reads for the customer tracking page
      allow get: if true;

      // Allow reads for authenticated users based on their role
      allow list: if request.auth != null && (
        getUserRole(request.auth.uid) == 'admin' ||
        getUserRole(request.auth.uid) == 'employee'
      );
      
      // Allow authenticated users to create orders
      allow create: if request.auth != null;

      // Allow updates based on role
      // Admins and employees can update any order.
      // Installers can only update orders assigned to them.
      allow update: if request.auth != null && (
        getUserRole(request.auth.uid) == 'admin' ||
        getUserRole(request.auth.uid) == 'employee' ||
        (getUserRole(request.auth.uid) == 'installer' && request.auth.uid == resource.data.assignedTo)
      );

      // Only admins can delete orders
      allow delete: if request.auth != null && getUserRole(request.auth.uid) == 'admin';
    }
  }
}
