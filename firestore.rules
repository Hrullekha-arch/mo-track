rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all documents for authenticated users
    match /{document=**} {
      allow read: if request.auth != null;
    }
    
    // Allow users to be created by anyone, but only the user or an admin can modify/delete them
    match /users/{userId} {
      allow read, write: if request.auth != null;
      // allow create: if true;
      // allow update, delete: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /orders/{orderId} {
       allow write: if request.auth != null;
       allow update: if request.auth != null && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fullKittingTime', 'fullKittingTimeReupdated']));
    }
    
    match /customers/{customerId}/{document=**} {
      allow write: if request.auth != null;
    }
    
    match /purchaseRequests/{requestId} {
      allow write: if request.auth != null;
    }
    
     match /inbounds/{inboundId} {
      allow write: if request.auth != null;
    }
    
    match /stocks/{stockId}/{document=**} {
       allow write: if request.auth != null;
    }

    match /Cutting/{taskId} {
      allow write: if request.auth != null;
    }

    match /invoiceBatches/{batchId} {
      allow write: if request.auth != null;
    }
    
    match /invoices/{invoiceId} {
      allow write: if request.auth != null;
    }

     match /o2d/{dealId} {
      allow write: if request.auth != null;
    }

    match /salesmanCrmAssignments/{salesmanName} {
      allow write: if request.auth != null;
    }
     match /taxDetails/{hsnCode} {
      allow write: if request.auth != null;
    }
  }
}
