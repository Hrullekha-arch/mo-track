
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check user role
    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Helper function to check multiple roles
    function isOneOfRoles(roles) {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return userRole in roles;
    }

    // Users collection rules
    match /users/{userId} {
      // Any authenticated user can read user profiles (for names, etc.)
      // Admins can do anything
      allow read: if request.auth != null;
      allow write: if isRole('admin');
    }
    
    // Allow listing users for authenticated users
    match /users/{path=**} {
      allow list: if request.auth != null;
    }

    // Orders collection rules
    match /orders/{orderId} {
      // Unauthenticated can read for tracking
      allow get: if request.auth == null;
      
      // Admins/Employees can read/write any order
      allow read, write: if request.auth != null && isOneOfRoles(['admin', 'employee']);

      // Installers can read/update their assigned orders
      allow read, update: if request.auth != null && isRole('installer') && resource.data.assignedTo == request.auth.uid;
    }
    
    // Allow listing orders for admins/employees
    match /orders/{path=**} {
      allow list: if request.auth != null && isOneOfRoles(['admin', 'employee']);
    }

    // Salesman to CRM Assignments rules
    match /salesmanCrmAssignments/{assignmentId} {
        // Admins and employees (like PC/CRM) can read and write assignments
        allow read, write: if request.auth != null && isOneOfRoles(['admin', 'employee']);
    }
    
    match /salesmanCrmAssignments/{path=**} {
        allow list: if request.auth != null && isOneOfRoles(['admin', 'employee']);
    }

  }
}
