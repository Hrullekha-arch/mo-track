rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin or specific employee roles
    function isAppAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCrm() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.designation == 'CRM';
    }
    
    function isEmployee() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee';
    }

    // Default: Deny all reads/writes unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    // Allow users to read other user profiles (for names, etc.)
    // Allow users to create their own profile, and admins to create any
    // Allow users to update their own profile, and admins to update any
    // Allow only admins to delete users
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId || isAppAdmin();
      allow update: if request.auth.uid == userId || isAppAdmin();
      allow delete: if isAppAdmin();
    }
    
    // Salesman to CRM Assignments
    // Only admins and designated employees (PC) should be able to manage assignments.
    match /salesmanCrmAssignments/{salesmanId} {
      allow read: if request.auth != null;
      allow write: if isAppAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.designation == 'PC';
    }

    // Orders Collection
    match /orders/{orderId} {
      // Read access for admin, assigned installer, or assigned CRM employee. Other employees cannot read all orders.
      allow read: if isAppAdmin() || resource.data.assignedTo == request.auth.uid || resource.data.handledByCrm == request.auth.uid;
      
      // Allow creation by admins or employees (PC)
      allow create: if isAppAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.designation == 'PC';
      
      // Allow updates by admin, employee (who is assigned as CRM), or assigned installer
      allow update: if isAppAdmin() || (isEmployee() && resource.data.handledByCrm == request.auth.uid) || resource.data.assignedTo == request.auth.uid;
      
      // Allow deletion only by admin
      allow delete: if isAppAdmin();
    }
    
    // Approved Orders and Quotations (for logging purposes)
    match /approvedOrders/{orderId} {
        allow write: if request.auth != null; // Allow any authenticated user to log an approval
        allow read: if isAppAdmin() || isEmployee();
    }
    
    match /approvedQuotations/{quotationId} {
        allow write: if request.auth != null; // Allow any authenticated user to log an approval
        allow read: if isAppAdmin() || isEmployee();
    }

    // Purchase Requests Collection
    match /purchaseRequests/{requestId} {
      allow read, write: if isAppAdmin() || isEmployee();
    }

    // Stock Collection
    match /stocks/{stockId} {
      allow read: if request.auth != null;
      allow write: if isAppAdmin(); // Only admins can import/modify stock
    }

    // Customer and their subcollections
    match /customers/{customerId} {
      // Allow read/write for admins and employees
      allow read, write: if isAppAdmin() || isEmployee();

      // Deals subcollection
      match /deals/{dealId} {
        allow read, write: if isAppAdmin() || isEmployee();

        // Quotations and Orders subcollections within a deal
        match /quotations/{quotationId} {
          allow read, write: if isAppAdmin() || isEmployee();
        }
        
        match /orders/{dealOrderId} {
           allow read, write: if isAppAdmin() || isEmployee();
        }

        match /visits/{visitId} {
           allow read, write: if request.auth != null; // Allow installers to read/write their assigned visits as well
        }
        
        match /measurements/{measurementId} {
           allow read, write: if isAppAdmin() || isEmployee();
        }

        match /cpds/{cpdId} {
           allow read, write: if isAppAdmin() || isEmployee();
        }
      }
    }
    
    // Rule for Collection Group Query used in /approve-quotation and /approve-order
    match /{path=**}/quotations/{quotationId} {
      allow read: if request.auth != null;
    }
     match /{path=**}/visits/{visitId} {
      allow read: if request.auth.uid != null;
    }
  }
}
