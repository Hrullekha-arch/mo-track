rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user has a specific role
    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    // Helper function to check if a user has one of several roles
    function hasAnyRole(roles) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    
    // Helper function to check if user is admin or specific employee types
    function isStaff() {
        return hasAnyRole(['admin', 'employee']);
    }

    // Users collection rules
    match /users/{userId} {
      // Anyone can read user info (e.g., for display names)
      allow read: if isAuthenticated();
      // Only admins can create or delete users
      allow create, delete: if hasRole('admin');
      // A user can update their own info, or an admin can update anyone's info
      allow update: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }
    
    // Customers collection rules
    match /customers/{customerId} {
        allow read, write: if isStaff();
        
        // Rules for subcollections of customers
        match /{allSubcollections}/{docId} {
            allow read, write: if isStaff();
        }

        match /visits/{visitId} {
            allow read, write: if isStaff();
            allow update: if isAuthenticated() && resource.data.assignedTo == request.auth.uid;
        }
    }
    
    // O2D collection rules
    match /o2d/{dealId} {
        allow read, write: if isStaff();
        // Allow installers to update, but only specific fields (if needed later)
        allow update: if isAuthenticated() && get(/databases/$(database)/documents/orders/{dealId}).data.assignedTo == request.auth.uid;
    }

    // Orders collection rules
    match /orders/{orderId} {
        // Staff can read and write all orders
        allow read, write: if isStaff();
        
        // Installers can read and update orders assigned to them
        allow read, update: if isAuthenticated() && resource.data.assignedTo == request.auth.uid;

        // Any authenticated user can track their own order if they have the code (for the tracking page)
        // This is a broad read, but data in orders should be customer-safe.
        allow get: if isAuthenticated();
        
        match /{allSubcollections}/{docId} {
            allow read, write: if isStaff();
        }
    }
    
    // Rules for collection groups
    match /{path=**}/visits/{visitId} {
        // Admins and employees can list all visits
        // Installers can only read visits assigned to them
        allow read: if isStaff() || (isAuthenticated() && get(/databases/$(database)/documents/{path}/visits/$(visitId)).data.assignedTo == request.auth.uid);
    }
    
    // Purchase Requests and Inbounds
    match /purchaseRequests/{requestId} {
        allow read, write: if isStaff();
    }
    
    match /inbounds/{inboundId} {
        allow read, write: if isStaff();
    }
    
    // Inventory and Transactions
    match /stocks/{stockId} {
        allow read: if isAuthenticated();
        allow write: if isStaff();

        match /{allSubcollections}/{docId} {
             allow read, write: if isStaff();
        }
    }
    
    // Salesman to CRM Assignments
    match /salesmanCrmAssignments/{salesmanId} {
        allow read, write: if hasRole('admin');
    }

    // Invoices and Cutting
    match /invoices/{invoiceId} {
      allow read, write: if isStaff();
    }

    match /Cutting/{taskId} {
      allow read, write: if isStaff();
    }
    
     match /approvedQuotations/{quotationId} {
      allow read, write: if isStaff();
    }
  }
}
