
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user has a specific role
    function hasRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Admins can read and write all documents
    match /{document=**} {
      allow read, write: if hasRole('admin');
    }

    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || hasRole('admin');
    }

    // Rules for customers
    match /customers/{customerId} {
      // Authenticated users can read/create customers
      allow read, create: if isAuthenticated();
      
      // Only admins or assigned CRMs/Salesmen can update
      allow update: if hasRole('admin') || hasRole('employee');
      
      // Deals subcollection
      match /deals/{dealId} {
        allow read, create, update: if isAuthenticated();

        // Quotations and Orders sub-subcollections
        match /{subcollection}/{docId} {
           allow read, create, update: if isAuthenticated();
        }
      }
    }
    
    // Rule for the 'visits' collection group
    match /{path=**}/visits/{visitId} {
      allow read: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || hasRole('admin') || hasRole('employee'));
      allow update: if isAuthenticated() && (resource.data.assignedTo == request.auth.uid || hasRole('admin') || hasRole('employee'));
    }

    // Authenticated users can read most top-level collections
    match /orders/{orderId} {
      allow read, update: if isAuthenticated();
    }
    match /purchaseRequests/{requestId} {
      allow read, update: if isAuthenticated();
    }
     match /inbounds/{inboundId} {
      allow read, update: if isAuthenticated();
    }
    match /Cutting/{taskId} {
      allow read, update: if isAuthenticated();
    }

    // Public tracking access for orders (read-only)
    match /orders/{orderId} {
      allow get: if true;
    }
    
    // Installers can only update orders assigned to them
    match /orders/{orderId} {
        allow update: if isAuthenticated() && (
            hasRole('installer') && resource.data.assignedTo == request.auth.uid
        );
    }
    
    // Allow read access to stocks for authenticated users
    match /stocks/{stockId} {
        allow read: if isAuthenticated();
    }
  }
}
