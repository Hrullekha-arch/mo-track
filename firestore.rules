rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to a specific document for testing or public data
    match /public/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Users collection rules
    match /users/{userId} {
      // Anyone can create a user document (on signup)
      allow create: if request.auth != null;
      // Only the user themselves or an admin can read/update their own data
      allow read, update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Only admins can delete users
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Customers and subcollections
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
      
      match /deals/{dealId} {
        allow read, write: if request.auth != null;
        
        match /visits/{visitId} {
          allow read: if request.auth != null;
          allow create, update: if request.auth != null;
        }

        match /{subcollection}/{docId} {
           allow read, write: if request.auth != null;
        }
      }
    }

    // Orders collection: Allow read/write for authenticated users.
    // Restrict updates to only the assigned installer or an admin/employee.
    match /orders/{orderId} {
       allow read, create: if request.auth != null;
       allow update: if request.auth != null && 
                      (request.auth.uid == resource.data.assignedTo || 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'employee']);
       allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // O2D collection: Allow read/write for authenticated users.
    match /o2d/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
    
    // All other collections can be read/written by any authenticated user.
    // This is a broad rule and should be refined for production.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
