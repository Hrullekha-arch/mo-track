
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ==================================================================
    //                        Helper Functions
    // ==================================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isEmployee() {
      return isAuthenticated() && getUserData().role == 'employee';
    }

    function isInstaller() {
      return isAuthenticated() && getUserData().role == 'installer';
    }
    
    function isAccounts() {
       return isAuthenticated() && getUserData().role == 'Accounts';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==================================================================
    //                        Global Rules
    // ==================================================================
    
    // Admins have god-mode. They can read/write anything, anywhere.
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // ==================================================================
    //                      Collection-Specific Rules
    // ==================================================================

    // --- Users Collection ---
    // Any authenticated user can read user profiles (to get names, etc.)
    // Only admins can modify user profiles (handled by the global admin rule)
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Write is covered by global admin rule.
    }

    // --- Customer Data (Customers, Deals, Quotations, etc.) ---
    // Employees can manage all customer-related data.
    // Admin access is already granted globally.
    match /customers/{customerId}/{document=**} {
      allow read, write: if isEmployee();
    }
    
    // --- Standalone Approved Quotations Collection ---
    match /approvedQuotations/{quotationId} {
        allow read, write: if isEmployee();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Employees can read/create/delete orders.
      allow read, create, delete: if isEmployee();
      
      // Installers can only read orders assigned to them.
      allow read: if isInstaller() && resource.data.assignedTo == request.auth.uid;
      
      // Update rules are more granular.
      allow update: if isEmployee() || 
                      (isInstaller() && resource.data.assignedTo == request.auth.uid && request.resource.data.keys().hasOnly(['milestones', 'feedbackRating', 'feedbackRemarks', 'bypassedOtp']));
                      
      // Allow public access ONLY for the tracking page (read-only 'get').
      allow get: if true;
    }

    // --- Purchase & Inbound ---
    match /purchaseRequests/{requestId} {
        allow read, write: if isEmployee() || isAccounts();
    }

    match /inbounds/{inboundId}/{document=**} {
        allow read, write: if isEmployee();
    }
    
    // --- Inventory & Stock Transactions ---
    // Only allow authenticated users to read stock levels.
    // Writes are denied from the client to force using server-side logic for safety.
    match /stocks/{stockId}/{document=**} {
        allow read: if isAuthenticated();
        allow write: if false; // Must be updated via server-side actions
    }
    
    // --- Assignments ---
    match /salesmanCrmAssignments/{salesmanId} {
        allow read, write: if isEmployee();
    }
  }
}
