rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write access to all users on the 'users' collection
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /salesmanCrmAssignments/{salesmanId} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to perform actions based on their role
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow update if the user is an admin or employee
      allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'employee'];
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Allow read/write access to all users on all subcollections of 'customers'
    match /customers/{customerId}/{document=**} {
        allow read, write: if request.auth != null;
    }
    
    match /purchaseRequests/{requestId} {
        allow read, write: if request.auth != null;
    }
    
     match /o2d/{o2dId} {
        allow read, write: if request.auth != null;
    }

    match /stocks/{stockId}/{document=**} {
        allow read, write: if request.auth != null;
    }
    
    match /taxDetails/{taxId} {
        allow read, write: if request.auth != null;
    }
    
    match /invoices/{invoiceId} {
        allow read, write: if request.auth != null;
    }

    match /invoiceBatches/{batchId} {
        allow read, write: if request.auth != null;
    }
    
    match /Cutting/{cuttingId} {
      allow read, write: if request.auth != null;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
