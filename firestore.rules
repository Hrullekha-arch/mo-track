
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions to check user roles and designations
    function isAppAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isDesignation(designation) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.designation == designation;
    }

    // Default: Deny all reads/writes unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection: Users can read profiles, but only update their own or be managed by an admin.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isAppAdmin(); // Only admin can create new users via the panel
      allow update: if request.auth.uid == userId || isAppAdmin();
      allow delete: if isAppAdmin();
    }
    
    // Salesman to CRM Assignments: Only admins or employees with 'PC' designation can manage.
    match /salesmanCrmAssignments/{salesmanId} {
      allow read: if request.auth != null;
      allow write: if isAppAdmin() || isDesignation('PC');
    }

    // Orders Collection: Granular access based on role and assignment.
    match /orders/{orderId} {
      // Admins and PCs can read all orders.
      // CRMs can read orders assigned to them.
      // Installers can read orders assigned to them.
      allow read: if isAppAdmin() 
                  || isDesignation('PC') 
                  || (isDesignation('CRM') && resource.data.handledByCrm == request.auth.uid)
                  || (isRole('installer') && resource.data.assignedTo == request.auth.uid);
      
      // Admins or PCs can create orders.
      allow create: if isAppAdmin() || isDesignation('PC');
      
      // Admin/PC/CRM can update their assigned orders. Installers can update their assigned orders.
      allow update: if isAppAdmin() 
                  || isDesignation('PC')
                  || (isDesignation('CRM') && resource.data.handledByCrm == request.auth.uid)
                  || (isRole('installer') && resource.data.assignedTo == request.auth.uid);
      
      // Only admins can delete.
      allow delete: if isAppAdmin();
    }
    
    // Purchase Requests Collection: Accessible by admins and employees (PC, CRM, etc).
    match /purchaseRequests/{requestId} {
      allow read, write: if isAppAdmin() || isRole('employee');
    }

    // Stock Collection: Read-only for authenticated users, writeable only by admin.
    match /stocks/{stockId} {
      allow read: if request.auth != null;
      allow write: if isAppAdmin();
    }

    // Customer data is generally managed by employees and admins.
    match /customers/{customerId} {
      allow read, write: if isAppAdmin() || isRole('employee');

      match /deals/{dealId} {
        allow read, write: if isAppAdmin() || isRole('employee');

        match /quotations/{quotationId} {
           allow read, write: if isAppAdmin() || isRole('employee');
        }
        
        match /orders/{dealOrderId} {
           allow read, write: if isAppAdmin() || isRole('employee');
        }

        // Installers also need to access visit data for their assigned tasks.
        match /visits/{visitId} {
           allow read, write: if request.auth != null;
        }
        
        match /measurements/{measurementId} {
           allow read, write: if isAppAdmin() || isRole('employee');
        }

        match /cpds/{cpdId} {
           allow read, write: if isAppAdmin() || isRole('employee');
        }
      }
    }
    
    // Collection Group Queries
    // Allows querying 'quotations' across all customers for the approval page.
    match /{path=**}/quotations/{quotationId} {
      allow read: if isAppAdmin() || isRole('employee');
    }

    // Allows querying 'visits' across all customers for the installer's visit list.
     match /{path=**}/visits/{visitId} {
      allow read: if request.auth != null;
    }
  }
}
