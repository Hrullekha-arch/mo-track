
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if a user is an employee (includes various designations)
    function isEmployee() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return role == 'employee' || role == 'Accounts' || role == 'Hr';
    }

    // Helper function to check if a user is an installer
    function isInstaller() {
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'installer';
    }
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users Collection
    match /users/{userId} {
      // Admins can read/write any user.
      // Any authenticated user can read the list of users (for dropdowns).
      // A user can update their own document, but cannot change their role.
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      // Anyone can read a single order for tracking purposes.
      allow get: if true;
      
      // List, create, update, delete permissions
      allow list: if isAdmin() || isEmployee() || isInstaller();
      allow create: if isAdmin() || isEmployee();
      allow update: if isAdmin() || isEmployee() || (isInstaller() && resource.data.assignedTo == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Purchase Requests Collection
    match /purchaseRequests/{requestId} {
       allow read, write: if isAdmin() || isEmployee();
    }

    // Salesman to CRM Assignments Collection
    match /salesmanCrmAssignments/{salesmanName} {
       allow read, write: if isAdmin() || isEmployee();
    }
  }
}
